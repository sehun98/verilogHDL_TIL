#ifndef INC_DRIVER_SPI_SPI_H_
#define INC_DRIVER_SPI_SPI_H_

#include <stdint.h>

#define SPI_BASE XPAR_AXI_SPI_MASTER_V1_0_0_BASEADDR

#define SPI ((SPI_TypeDef *)SPI_BASE)

typedef struct
{
	volatile uint32_t CR;  /*!< SPI control register,                   Address offset: 0x00 */
    volatile uint32_t SR; /*!< SPI Input register,                     Address offset: 0x04 */
    volatile uint32_t DR; /*!< SPI Output register,                    Address offset: 0x08 */
} SPI_TypeDef;

// SPI_CR
// reserved[31:9] LSBFirst[8] DFF[7] MSTR[6] start[5] spi_br[4:2] cpol[1] cpha[0]
// SPI_SR
// reserved[31:4] tx_busy[3] tx_overrun_error[2] rx_done[1] rx_frame_error[0]

#define UART_CR_UE_Pos       2U
#define UART_CR_BRR_Pos      3U

#define UART_CR_RXE_Msk      (1U << UART_CR_RXE_Pos)
#define UART_CR_TXE_Msk      (1U << UART_CR_TXE_Pos)
#define UART_CR_UE_Msk       (1U << UART_CR_UE_Pos)
#define UART_CR_BRR_Msk      (7U << UART_CR_BRR_Pos)

#endif /* INC_DRIVER_SPI_SPI_H_ */
