#include <stdint.h>

#define GPIO_BASE 0x40001000U
#define GPIO_CRL  (*(volatile uint32_t *)(GPIO_BASE + 0x00))
#define GPIO_CRH  (*(volatile uint32_t *)(GPIO_BASE + 0x04))
#define GPIO_IDR  (*(volatile uint32_t *)(GPIO_BASE + 0X08))
#define GPIO_ODR  (*(volatile uint32_t *)(GPIO_BASE + 0x0C))
#define GPIO_BSRR (*(volatile uint32_t *)(GPIO_BASE + 0x10))

#define GPIO_PA0 0x30000000
#define GPIO_PA1 0x03000000
#define GPIO_PA2 0x00300000
#define GPIO_PA3 0x00030000
#define GPIO_PA4 0x00003000
#define GPIO_PA5 0x00000300
#define GPIO_PA6 0x00000030
#define GPIO_PA7 0x00000003

#define GPIO_PA8 0x30000000
#define GPIO_PA9 0x03000000
#define GPIO_PA10 0x00300000
#define GPIO_PA11 0x00030000
#define GPIO_PA12 0x00003000
#define GPIO_PA13 0x00000300
#define GPIO_PA14 0x00000030
#define GPIO_PA13 0x00000003

static void delay(void)
{
    for (volatile int i = 0; i < 1000000; i++);
}

int main(void)
{
	// 0011_0011_0011_0011_0011_0011_0011_0011
	// [8] [9] [10] [11] [12] [13] [14] [15]
    GPIO_CRH = GPIO_PA8 | GPIO_PA9 | GPIO_PA10 | GPIO_PA11 | GPIO_PA12 | GPIO_PA13 | GPIO_PA14 | GPIO_PA15;  // gpio_pin[8]~[15] output

    while (1)
    {
        GPIO_ODR = 0x0000FF00;
        delay();

        GPIO_ODR = 0x00000000;
        delay();
    }

    return 0;
}
