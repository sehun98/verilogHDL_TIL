#include "xparameters.h"
#include "xil_printf.h"
#include "xintc.h"
#include "../inc/Driver/GPIO/gpio.h"
#include "../inc/Driver/UART/uart.h"
#include "../inc/Driver/TIM/tim.h"
#include "../inc/Driver/FND/fnd.h"
#include "../inc/Driver/I2C/i2c.h"
#include "../inc/Driver/SPI/spi.h"
#include "../inc/App/BUTTON/button.h"
#include "../inc/App/CLCD1602/clcd1602.h"
#include "../inc/Common/Interrupt/interrupt.h"

#include <stdint.h>
#include <stdio.h>
#include <string.h>
#include <stdbool.h>

void GPIOA_Init(void);
void GPIOB_Init(void);
void GPIOC_Init(void);
void TIM1_Init(void);
void TIM2_Init(void);

volatile bool counterFlag = false;
volatile bool sensorFlag = false;

volatile bool modeConvert = false; // false : fnd 1hz counter, true : light sensor

int main(void)
{
    char clcd_buf[17];
    char uart_buf[32];

    uint16_t spi_raw = 0;
    int fnd_value = 0;
    int sensor_value = 0;
    uint8_t uart_rx_data = 0;

    I2C_SetClockDivider(I2C, 250);
    I2C_Init(I2C);
    delay_ms(10);
    LCD_Init(I2C);

    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& begin
    LCD_Clear(I2C);
    LCD_SetCursor(I2C, 0, 0);
    LCD_Print(I2C, "I2C AXI4-Lite");
    LCD_SetCursor(I2C, 1, 0);
    LCD_Print(I2C, "Success!!");
    delay_ms(1000);
    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& end

    UART_Init(UART, 115200);
    UART_ClearInterruptFlag(UART, UART_IT_ALL);
    UART_EnableInterrupt(UART, UART_IT_RX);

    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& begin
    LCD_Clear(I2C);
    LCD_SetCursor(I2C, 0, 0);
    LCD_Print(I2C, "UART AXI4-Lite");
    LCD_SetCursor(I2C, 1, 0);
    LCD_Print(I2C, "Success!!");
    UART_WriteString(UART, "UART AXI4-Lite Success!!\r\n");
    delay_ms(1000);
    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& end

    FND_Init();
    FND_Display_On();

    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& begin
    for(int i = 0; i < 3; i++) {
        FND_Display_On();
        delay_ms(500);
        FND_Display_Off();
        delay_ms(500);
    }
    LCD_Clear(I2C);
    LCD_SetCursor(I2C, 0, 0);
    LCD_Print(I2C, "FND AXI4-Lite");
    LCD_SetCursor(I2C, 1, 0);
    LCD_Print(I2C, "Success!!");
    UART_WriteString(UART, "FND AXI4-Lite Success!!\r\n");
    delay_ms(1000);
    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& end

    GPIOA_Init(); // switch
    GPIOB_Init(); // led
    GPIOC_Init(); // button

    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& begin
    for(int i = 0; i < 4; i++) {
    	GPIO_TogglePin(GPIOB, GPIO_PIN_ALL);
        delay_ms(500);
    }
    LCD_Clear(I2C);
    LCD_SetCursor(I2C, 0, 0);
    LCD_Print(I2C, "GPIO AXI4-Lite");
    LCD_SetCursor(I2C, 1, 0);
    LCD_Print(I2C, "Success!!");
    UART_WriteString(UART, "GPIO AXI4-Lite Success!!\r\n");
    delay_ms(1000);
    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& end

    if (SetupInterruptSystem() != XST_SUCCESS) {
        return -1;
    }

    // 1ms
    TIM1_Init();
    TIM_ClearInterruptFlag(TIM1, TIM_IT_ALL);
    TIM_EnableInterrupt(TIM1, TIM_IT_UPDATE);
    TIM_Start(TIM1);
    TIM_PWM_Start(TIM1);

    // 250hz
    TIM2_Init();
    TIM_ClearInterruptFlag(TIM2, TIM_IT_ALL);
    TIM_EnableInterrupt(TIM2, TIM_IT_UPDATE);
    TIM_Start(TIM2);
    TIM_PWM_Start(TIM2);

    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& begin
    LCD_Clear(I2C);
    LCD_SetCursor(I2C, 0, 0);
    LCD_Print(I2C, "TIM AXI4-Lite");
    LCD_SetCursor(I2C, 1, 0);
    LCD_Print(I2C, "Success!!");
    UART_WriteString(UART, "TIM AXI4-Lite Success!!\r\n");
    delay_ms(1000);
    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& end

    SPI_Init(SPI); // LIGHT SENSOR

    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& begin
    LCD_Clear(I2C);
    LCD_SetCursor(I2C, 0, 0);
    LCD_Print(I2C, "SPI AXI4-Lite");
    LCD_SetCursor(I2C, 1, 0);
    LCD_Print(I2C, "Success!!");
    SPI_TransmitReceive16(SPI, 0x0000, &spi_raw);
    sensor_value = (spi_raw >> 4) & 0xFF;
    snprintf(uart_buf, sizeof(uart_buf), "SENSOR Value:%4d\r\n", sensor_value);
    UART_WriteString(UART, uart_buf);
    UART_WriteString(UART, "SPI AXI4-Lite Success!!\r\n");
    delay_ms(1000);
    // &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& end

    while (1)
    {
    	if(sensorFlag)
    	{
    		sensorFlag = 0;
            SPI_TransmitReceive16(SPI, 0x0000, &spi_raw);

            sensor_value = (spi_raw >> 4) & 0xFF;

            snprintf(clcd_buf, sizeof(clcd_buf), "SPI Value:%4d", sensor_value);
            snprintf(uart_buf, sizeof(uart_buf), "SPI Value : %d\r\n", sensor_value);

            LCD_SetCursor(I2C, 0, 0);
            LCD_Print(I2C, "SPI-AXI4-Lite");

            LCD_SetCursor(I2C, 1, 0);
            LCD_Print(I2C, clcd_buf);
            UART_WriteString(UART, uart_buf);
    	}
    	if(counterFlag)
    	{
    		counterFlag = 0;
    		fnd_value++;
    	}

    	FND_Data(fnd_value);

        if(buttons[0].flag)
        {
            buttons[0].flag = 0;
            GPIO_TogglePin(GPIOB, GPIO_PIN_0);
        }

        while (UART_ReadByteNonBlocking(UART, &uart_rx_data) != 0U)
        {
            UART_WriteByte(UART, uart_rx_data);
            UART_ClearInterruptFlag(UART, UART_IT_RX);
        }
    }

    return 0;
}

// Switches
void GPIOA_Init(void)
{
    GPIO_Set_Direction(GPIOA, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3 | GPIO_PIN_4 | GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7, GPIO_MODE_INPUT);
}

// LEDs
void GPIOB_Init(void)
{
    GPIO_Set_Direction(GPIOB, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3 | GPIO_PIN_4 | GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7, GPIO_MODE_OUTPUT);
    GPIO_WritePin(GPIOB, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3 | GPIO_PIN_4 | GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7, GPIO_PIN_RESET);
}

// button
void GPIOC_Init(void)
{
    GPIO_Set_Direction(GPIOC, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3 | GPIO_PIN_4, GPIO_MODE_INPUT);
}

void TIM1_Init(void)
{
    // 100_000_000 100MHz -> 100_000 100KHz -> 1000Hz 0.01s
    TIM_SetPrescaler(TIM1, 1000);
    TIM_SetAutoReload(TIM1, 100);
    TIM_SetCompareCapture(TIM1, 50);
    TIM_SetRunMode(TIM1, TIM_MODE_CONTINUOUS);
    TIM_SetCounterDirection(TIM1, TIM_COUNTER_UP);
}

void TIM2_Init(void)
{
    // 100_000_000 100MHz -> 10_000 10KHz -> 50Hz
    TIM_SetPrescaler(TIM2, 10000);
    TIM_SetAutoReload(TIM2, 200);
    TIM_SetCompareCapture(TIM2, 20);
    TIM_SetRunMode(TIM2, TIM_MODE_CONTINUOUS);
    TIM_SetCounterDirection(TIM2, TIM_COUNTER_UP);
}

