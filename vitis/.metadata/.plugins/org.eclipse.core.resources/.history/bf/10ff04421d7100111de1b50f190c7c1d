#ifndef INC_DRIVER_GPIO_GPIO_H_
#define INC_DRIVER_GPIO_GPIO_H_

/* Definitions for peripheral AXI_FND_V1_0_0 */
#define XPAR_AXI_FND_V1_0_0_BASEADDR 0x44A00000
#define XPAR_AXI_FND_V1_0_0_HIGHADDR 0x44A0FFFF


/* Definitions for peripheral AXI_SPI_MASTER_V1_0_0 */
#define XPAR_AXI_SPI_MASTER_V1_0_0_BASEADDR 0x44A30000
#define XPAR_AXI_SPI_MASTER_V1_0_0_HIGHADDR 0x44A3FFFF

#include <stdint.h>

#define XPAR_AXI_GPIOA_BASEADDR 0x44A10000
#define XPAR_AXI_GPIOB_BASEADDR 0x44A70000
#define XPAR_AXI_GPIOC_BASEADDR 0x44A80000

#define GPIOA_BASE XPAR_AXI_GPIOA_BASEADDR
#define GPIOB_BASE XPAR_AXI_GPIOB_BASEADDR
#define GPIOC_BASE XPAR_AXI_GPIOC_BASEADDR

#define GPIOA ((GPIO_TypeDef *)GPIOA_BASE)
#define GPIOB ((GPIO_TypeDef *)GPIOB_BASE)
#define GPIOC ((GPIO_TypeDef *)GPIOC_BASE)

#define GPIO_PIN_0    (1U << 0)
#define GPIO_PIN_1    (1U << 1)
#define GPIO_PIN_2    (1U << 2)
#define GPIO_PIN_3    (1U << 3)
#define GPIO_PIN_4    (1U << 4)
#define GPIO_PIN_5    (1U << 5)
#define GPIO_PIN_6    (1U << 6)
#define GPIO_PIN_7    (1U << 7)

#define GPIO_PIN_ALL  0x000000FFu
#define GPIO_PIN_MASK 0x0000FFFFu

typedef struct
{
	volatile uint32_t CR;  /*!< GPIO control register,                   Address offset: 0x00 */
    volatile uint32_t IDR; /*!< GPIO Input register,                     Address offset: 0x04 */
    volatile uint32_t ODR; /*!< GPIO Output register,                    Address offset: 0x08 */
} GPIO_TypeDef;

typedef enum
{
  GPIO_PIN_RESET = 0u,
  GPIO_PIN_SET
} GPIO_PinState;

typedef enum
{
  GPIO_MODE_INPUT = 0u,
  GPIO_MODE_OUTPUT
} GPIO_ModeState;

void GPIO_Set_Direction(GPIO_TypeDef *GPIOx, uint16_t GPIO_Pin, GPIO_ModeState Mode);
GPIO_PinState GPIO_ReadPin(GPIO_TypeDef *GPIOx, uint16_t GPIO_Pin);
void GPIO_WritePin(GPIO_TypeDef *GPIOx, uint16_t GPIO_Pin, GPIO_PinState PinState);
void GPIO_TogglePin(GPIO_TypeDef *GPIOx, uint16_t GPIO_Pin);

uint32_t GPIO_ReadPort(GPIO_TypeDef *GPIOx);
void GPIO_WritePort(GPIO_TypeDef *GPIOx, uint16_t PortData);

#endif /* INC_DRIVER_GPIO_GPIO_H_ */
