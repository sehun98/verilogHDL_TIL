#ifndef INC_DRIVER_I2C_I2C_H_
#define INC_DRIVER_I2C_I2C_H_



/* Definitions for peripheral AXI_FND_V1_0_0 */
#define XPAR_AXI_FND_V1_0_0_BASEADDR 0x44A00000
#define XPAR_AXI_FND_V1_0_0_HIGHADDR 0x44A0FFFF


/* Definitions for peripheral AXI_GPIO_V1_0_0 */
#define XPAR_AXI_GPIO_V1_0_0_BASEADDR 0x44A10000
#define XPAR_AXI_GPIO_V1_0_0_HIGHADDR 0x44A1FFFF


/* Definitions for peripheral AXI_GPIO_V1_0_1 */
#define XPAR_AXI_GPIO_V1_0_1_BASEADDR 0x44A70000
#define XPAR_AXI_GPIO_V1_0_1_HIGHADDR 0x44A7FFFF


/* Definitions for peripheral AXI_GPIO_V1_0_2 */
#define XPAR_AXI_GPIO_V1_0_2_BASEADDR 0x44A80000
#define XPAR_AXI_GPIO_V1_0_2_HIGHADDR 0x44A8FFFF


/* Definitions for peripheral AXI_I2C_MASTER_V1_0_0 */
#define XPAR_AXI_I2C_MASTER_V1_0_0_BASEADDR 0x44A20000
#define XPAR_AXI_I2C_MASTER_V1_0_0_HIGHADDR 0x44A2FFFF


/* Definitions for peripheral AXI_SPI_MASTER_V1_0_0 */
#define XPAR_AXI_SPI_MASTER_V1_0_0_BASEADDR 0x44A30000
#define XPAR_AXI_SPI_MASTER_V1_0_0_HIGHADDR 0x44A3FFFF

#include <stdint.h>

// I2C_CR bits
#define I2C_EN_Pos      0U
#define I2C_START_Pos   1U
#define I2C_STOP_Pos    2U
#define I2C_WRITE_Pos   3U
#define I2C_READ_Pos    4U
#define I2C_ACK_Pos     5U

#define I2C_EN_Msk      (1U << I2C_EN_Pos)
#define I2C_START_Msk   (1U << I2C_START_Pos)
#define I2C_STOP_Msk    (1U << I2C_STOP_Pos)
#define I2C_WRITE_Msk   (1U << I2C_WRITE_Pos)
#define I2C_READ_Msk    (1U << I2C_READ_Pos)
#define I2C_ACK_Msk     (1U << I2C_ACK_Pos)

#define I2C_SR_BUSY_Pos   0U
#define I2C_SR_DONE_Pos   1U
#define I2C_SR_NACK_Pos   2U
#define I2C_SR_ARLOS_Pos  3U

#define I2C_SR_BUSY_Msk   (1U << I2C_SR_BUSY_Pos)
#define I2C_SR_DONE_Msk   (1U << I2C_SR_DONE_Pos)
#define I2C_SR_NACK_Msk   (1U << I2C_SR_NACK_Pos)
#define I2C_SR_ARLOS_Msk  (1U << I2C_SR_ARLOS_Pos)

#define XPAR_I2C_MASTER_V1_0_0_BASEADDR    XPAR_I2C_MASTER_V1_0_0_BASEADDR
#define I2C_MASTER_BASE_ADDR    XPAR_I2C_MASTER_V1_0_0_BASEADDR

#define I2C ((I2C_TypeDef *)I2C_MASTER_BASE_ADDR)

typedef struct
{
    volatile uint32_t CR;  /*!< I2C Control register,             Address offset: 0x00 */
    volatile uint32_t SR; /*!< I2C Status register,               Address offset: 0x04 */
    volatile uint32_t DR; /*!< I2C Data register,                 Address offset: 0x08 */
    volatile uint32_t CLKDIV; /*!< I2C Clock Div register,        Address offset: 0x0C */
} I2C_TypeDef;

#endif /* INC_DRIVER_I2C_I2C_H_ */
