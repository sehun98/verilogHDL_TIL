<?xml version="1.0" encoding="UTF-8"?>
<sdx:platform sdx:vendor="xilinx.com"
              sdx:library="sdx"
              sdx:name="apb_spi"
              sdx:version="1.0"
              sdx:schemaVersion="1.0"
              xmlns:sdx="http://www.xilinx.com/sdx">
    <sdx:description>
apb_spi
    </sdx:description>
    <sdx:systemConfigurations sdx:defaultConfiguration="apb_spi">
        <sdx:configuration sdx:name="apb_spi"
                           sdx:displayName="apb_spi"
                           sdx:defaultProcessorGroup="standalone_domain"
                           sdx:runtimes="cpp">
            <sdx:description>apb_spi</sdx:description>
            <sdx:bootImages sdx:default="standard">
                <sdx:image sdx:name="standard"
                            sdx:bif="apb_spi/boot/apb_spi.bif"
                            sdx:readme="apb_spi/boot/generic.readme"
                            />
            </sdx:bootImages>
            <sdx:processorGroup sdx:name="standalone_domain"
                                sdx:displayName="standalone_domain"
                                sdx:cpuType="microblaze_0"
                                sdx:cpuInstance="microblaze_0">
                <sdx:os sdx:name="standalone"
                        sdx:displayName="standalone"
                        sdx:bspLibraryPaths="apb_spi/standalone_domain/bsplib/lib"
                        sdx:bspIncludePaths="apb_spi/standalone_domain/bspinclude/include"
                        sdx:bspConfig="apb_spi/standalone_domain/system.mss"
                />
            </sdx:processorGroup>
        </sdx:configuration>
    </sdx:systemConfigurations>
</sdx:platform>
